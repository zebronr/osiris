{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/analyze_date.php",
      "dest": "/analyze_date.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
